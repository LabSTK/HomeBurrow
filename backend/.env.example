# ---- Database ----
DATABASE_URL=postgresql+asyncpg://homeburrow:homeburrow@db:5432/homeburrow

# ---- Auth / JWT ----
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- File storage ----
# Absolute path inside the container where uploaded files are stored
STORAGE_PATH=/app/storage_data
